# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# IAM Identity Center OIDC
SSO_ISSUER_URL=https://your-identity-center-instance.awsapps.com/sso
SSO_CLIENT_ID=your-client-id
SSO_CLIENT_SECRET=your-client-secret

# App Configuration
APP_REGION=ap-south-1
APP_ACCOUNT_ID=your-account-id
PORTAL_ROLE_ARN=arn:aws:iam::your-account-id:role/IAMAccessHub-PortalRole

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Limits
MAX_SESSION_DURATION_HOURS=4
DEFAULT_SESSION_DURATION_HOURS=1
MAX_CONCURRENT_SESSIONS=2
MAX_REQUESTS_PER_HOUR=5
