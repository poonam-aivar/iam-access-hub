# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# AWS IAM Identity Center OIDC
AWS_SSO_ISSUER_URL=https://your-identity-center-instance.awsapps.com/sso
AWS_SSO_CLIENT_ID=your-client-id
AWS_SSO_CLIENT_SECRET=your-client-secret

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-account-id

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# App Config
MAX_SESSION_DURATION_HOURS=4
DEFAULT_SESSION_DURATION_HOURS=1
MAX_CONCURRENT_SESSIONS=2
MAX_REQUESTS_PER_HOUR=5
